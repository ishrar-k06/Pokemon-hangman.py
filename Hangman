import random

def choose_word():
    with open("pokemon-2.txt", "r") as file: #open
        content = file.read() #read

        words = content.split(",") #split

        cleaned_words = [] #empty list
        for word in words:
            cleaned = word.strip().lower() #clean
            cleaned_words.append(cleaned) #add to the list

        return random.choice(cleaned_words)

def display_word(hidden_word, guessed_letters):
    progress = " "
    for letter in hidden_word:
        if letter in guessed_letters: 
            progress += letter + " "
        else:
            progress +="_ "
    print(progress.strip())

def is_word_guessed(hidden_word, guessed_letters):
    for letter in hidden_word:
        if letter not in guessed_letters:
            return False
    return True

hidden_word = choose_word()
guessed_letters = []
turns = 0

print("🎮 Welcome to Pokémon Hangman!\n")

while not is_word_guessed(hidden_word, guessed_letters):
    print(f"\nTurn: {turns}")
    display_word(hidden_word, guessed_letters)
    print("Guessed letters:", " ".join(guessed_letters))

    guess = input("Enter a letter: ").lower()

    if not guess.isalpha() or len(guess) != 1:
        print("❌ Please enter a SINGLE alphabet letter.")
        continue

    if guess in guessed_letters:
        print("⚠️ You already guessed that letter!")
        continue

    # --- PROCESS GUESS ---
    guessed_letters.append(guess)
    turns += 1

    if guess in hidden_word:
        print("✅ Correct!")
    else:
        print("❌ Wrong!")

print("\n🎉 Congratulations!")
print(f"You guessed the word: {hidden_word}")
print(f"It took you {turns} turns.")
